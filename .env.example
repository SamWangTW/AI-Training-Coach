# ── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Memory (pick one) ────────────────────────────────────────────────────────
# Option A: mem0 hosted — best memory extraction, zero local setup
#   Get your key at https://app.mem0.ai
MEM0_API_KEY=

# Option B: mem0 local — uses Anthropic LLM for extraction, no extra key needed
#   Leave MEM0_API_KEY blank and mem0 will run locally using ANTHROPIC_API_KEY.

# Option C: simple JSON fallback — works with no additional keys
#   Automatically used if neither mem0 option works.

# ── Observability (optional) ─────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=garmin-training-coach
